{
  "info": {
    "_postman_id": "dccebf86-3c76-4f34-a6bb-5f7d54dcb605",
    "name": "SafeBase API",
    "description": "Vérifications manuelles et automatisables de l'API SafeBase construite depuis l'image Docker.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/health",
        "description": "Vérifie que le conteneur API répond."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Réponse ok', function () { pm.expect(pm.response.text()).to.eql('ok'); });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Geocoding suggestions",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/geocoding/suggestions?q=Marseille&limit=5",
        "description": "Exemple d'endpoint public. Nécessite que l'API ait accès à ses dépendances."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": ["pm.test('HTTP 200', function () { pm.response.to.have.status(200); });"],
            "type": "text/javascript"
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" }
  ]
}
