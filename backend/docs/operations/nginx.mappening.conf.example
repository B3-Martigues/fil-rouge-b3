# Exemple de configuration Nginx pour l'API Mappening.
# Adapter les chemins, le domaine et l'upstream avant usage.

upstream mappening_api {
    server 127.0.0.1:8080;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name api.mappening.example.fr;

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/letsencrypt;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name api.mappening.example.fr;

    ssl_certificate /etc/letsencrypt/live/api.mappening.example.fr/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.mappening.example.fr/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_session_timeout 1d;
    ssl_session_cache shared:TLSCache:10m;
    ssl_session_tickets off;

    client_max_body_size 25m;
    keepalive_timeout 65;

    location /api/ {
        proxy_pass http://mappening_api;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host $host;

        proxy_set_header Connection "";
        proxy_redirect off;
        proxy_buffering off;
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
    }
}
