# Copiez ce fichier vers `.env.local` pour le developpement local uniquement.
#
# ATTENTION SECURITE :
# - `.env.local` ne doit JAMAIS etre commit (il est dans `.gitignore`)
# - utilisez `.env.example` comme modele de configuration
# - tous les secrets doivent etre regenes pour chaque environnement
# - en production, injectez les secrets via la plateforme de deploiement
#   (Docker, Kubernetes, systemd, etc.), pas via des fichiers `.env`

# =========================
# Environnement
# =========================
ENV=dev  # Valeurs possibles : dev, staging, production

# =========================
# API
# =========================
ADDR=127.0.0.1:8080

# =========================
# JWT
# =========================
# SECURITE : `JWT_SECRET` doit etre aleatoire et cryptographiquement robuste.
# Pour le developpement : n'importe quelle valeur fonctionne.
# Pour la production : generez-la avec `openssl rand -hex 32`.
# Un minimum de 32 caracteres est requis en production.
JWT_SECRET=replace-with-a-local-dev-secret-at-least-32-characters
JWT_ISSUER=mappening
JWT_TTL=15m                 # Duree de vie du jeton d'acces
REFRESH_TTL=168h            # Duree de vie du jeton de rafraichissement
# SECURITE :
# - doit etre une URL absolue d'origine uniquement (sans chemin, query ni fragment)
# - doit etre en HTTPS en production
# - ne doit jamais contenir d'identifiants
FRONTEND_URL=http://localhost:5173
COOKIE_SECURE=false         # Passez a `true` en production (HTTPS uniquement)
# Optionnel: domaine parent pour le cookie CSRF si le front et l'API sont sur
# des sous-domaines differents, ex: example.com pour app.example.com/api.example.com.
# Laisser vide si le front lit le token CSRF depuis la reponse de login/refresh.
CSRF_COOKIE_DOMAIN=

# =========================
# Connexion locale de dev
# =========================
# SECURITE : `DevLogin` doit etre DESACTIVE en production.
# L'email doit deja exister dans la base locale.
DEV_LOGIN_ENABLED=false
DEV_LOGIN_EMAIL=admin@mappening.local

# =========================
# Proxy
# =========================
# Liste des CIDR/IP de tes reverse proxies de confiance uniquement.
# Exemple : 127.0.0.1,10.0.0.0/8
# Le proxy doit ECRASER les en-tetes X-Forwarded-* entrants, pas les relayer tels quels.
TRUSTED_PROXY_CIDRS=

# =========================
# Documentation API publique
# =========================
# En production, laissez desactive sauf besoin explicite de publier Swagger.
PUBLIC_DOCS_ENABLED=false

# =========================
# Emails / notifications sortantes
# =========================
# MAIL_MODE:
# - log      : ecrit les emails dans les logs, pratique en dev
# - smtp     : envoie vraiment via SMTP
# - disabled : coupe les emails sortants
MAIL_MODE=log
MAIL_FROM=no-reply@mappening.local
MAIL_FROM_NAME=Mappening
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# =========================
# Base de donnees applicative
# =========================
# SECURITE :
# - en production, `APP_DB_SSLMODE=require` est requis pour une base distante
# - `disable` est acceptable uniquement si PostgreSQL ecoute en local sur le VPS
# - utilisez des roles separes pour l'application et les migrations
# - les mots de passe doivent etre renouveles regulierement
# - les chaines de connexion doivent etre injectees, pas stockees en `.env`
APP_DB_HOST=127.0.0.1
APP_DB_PORT=55432
APP_DB_NAME=mappening
APP_DB_USER=mappening_user
APP_DB_PASSWORD=mappening_app_password
APP_DB_SSLMODE=disable      # Passez a `require` si la base n'est pas locale
APP_DB_MAX_CONNS=20         # Taille max du pool de connexions
APP_DB_MAX_IDLE=10          # Nombre de connexions inactives conservees
APP_DB_MAX_LIFETIME=1h      # Recycle les connexions apres 1 heure

# =========================
# Base de donnees des migrations
# =========================
# SECURITE : utilisez un role separe, plus privilegie, pour les migrations.
# Ce role peut modifier le schema, contrairement au role applicatif.
MIGRATIONS_DB_HOST=127.0.0.1
MIGRATIONS_DB_PORT=55432
MIGRATIONS_DB_NAME=mappening
MIGRATIONS_DB_USER=mappening_migrator
MIGRATIONS_DB_PASSWORD=mappening_migrator_password
MIGRATIONS_DB_SSLMODE=disable      # Passez a `require` si la base n'est pas locale
MIGRATIONS_DB_MAX_CONNS=5
MIGRATIONS_DB_MAX_IDLE=2
MIGRATIONS_DB_MAX_LIFETIME=30m

# =========================
# CACHE
# =========================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=mappening_cache_password
REDIS_DB=0

# =========================
# Medias / uploads
# =========================
# En production, utilisez un dossier persistant hors du dossier de release.
MEDIA_UPLOAD_DIR=/var/lib/mappening/uploads

# =========================
# Scraping
# =========================
TARPIN_BIEN_SCRAPER_ENABLED=true
TARPIN_BIEN_USER_AGENT=MappeningBot/1.0 (+https://mappening.fr)
